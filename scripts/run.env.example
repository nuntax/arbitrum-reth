# Copy to scripts/run.env (gitignored) and fill in. Never commit real keys.
#
# Ethereum L1 (parent chain) endpoints. Any provider works; a paid archive tier is recommended
# for a full historical derivation.
L1_RPC="https://eth-mainnet.example/v2/YOUR_KEY"
L1_BEACON="https://eth-mainnetbeacon.example/v2/YOUR_KEY"

# Optional: sequencer feed relay to ride the tip once L1 derivation has caught up (ws:// or wss://).
# FEED_URL="wss://your-chain/feed"

# Optional overrides (defaults shown):
# CHAIN_INFO="crates/arb-reth-node/tests/fixtures/robinhood-chain-info.json"
# GENESIS="crates/arb-reth-node/tests/fixtures/robinhood-genesis.json"
# DATADIR="$HOME/.arb-reth/robinhood"
# HTTP_PORT="8545"
# L1_END_BLOCK=""        # set to stop derivation at a given L1 block (leave empty to follow the tip)
# L1_GETLOGS_RANGE="500"
